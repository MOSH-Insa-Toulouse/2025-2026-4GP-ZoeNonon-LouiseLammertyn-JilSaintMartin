import sys
import serial
import pyqtgraph as pg
from PyQt5.QtWidgets import QApplication, QMainWindow, QVBoxLayout, QWidget, QLabel
from PyQt5.QtCore import QTimer

class RealTimeGraph(QMainWindow):
    def __init__(self):
        super().__init__()

        # --- Configuration de la fenêtre ---
        self.setWindowTitle("Graphique de Résistance du Capteur")
        self.resize(800, 500)
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        self.layout = QVBoxLayout(self.central_widget)

        # --- Label pour la valeur en texte ---
        self.label_value = QLabel("Attente des données...")
        self.label_value.setStyleSheet("font-size: 20px; font-weight: bold; color: #2c3e50;")
        self.layout.addWidget(self.label_value)

        # --- Configuration du Graphique (PyQtGraph) ---
        self.graph_widget = pg.PlotWidget()
        self.graph_widget.setBackground('w') # Fond blanc
        self.graph_widget.showGrid(x=True, y=True)
        self.graph_widget.setLabel('left', 'Résistance', units='Ω')
        self.graph_widget.setLabel('bottom', 'Temps (échantillons)')
        self.layout.addWidget(self.graph_widget)

        # Données du graph
        self.max_points = 200 # Nombre de points affichés à l'écran
        self.data_x = list(range(self.max_points))
        self.data_y = [0.0] * self.max_points
        self.line = self.graph_widget.plot(self.data_x, self.data_y, pen=pg.mkPen(color='b', width=2))

        # --- Connexion Série ---
        # REMPLACE 'COM3' par ton port (ex: '/dev/ttyUSB0' sur Linux/Mac)
        try:
            self.ser = serial.Serial('COM7', 9600, timeout=0.1)
        except Exception as e:
            self.label_value.setText(f"Erreur Port Série: {e}")
            self.ser = None

        # --- Timer pour mettre à jour le graph ---
        self.timer = QTimer()
        self.timer.setInterval(30) # 30ms = fluide
        self.timer.timeout.connect(self.update_plot)
        self.timer.start()

    def update_plot(self):
        if self.ser and self.ser.in_waiting > 0:
            try:
                # Lecture de la ligne envoyée par l'Arduino
                line = self.ser.readline().decode('utf-8').strip()
                if line:
                    value = float(line)
                    
                    # Mise à jour du label
                    self.label_value.setText(f"Résistance actuelle : {value:.2f} Ω")

                    # Décalage des données (Scrolling graph)
                    self.data_y = self.data_y[1:] + [value]
                    self.line.setData(self.data_x, self.data_y)
            except Exception as e:
                print(f"Erreur de lecture: {e}")

    def closeEvent(self, event):
        if self.ser:
            self.ser.close()
        event.accept()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = RealTimeGraph()
    window.show()
    sys.exit(app.exec_())