from PyQt5.QtWidgets import QApplication, QMainWindow, QVBoxLayout, QWidget, QLabel, QPushButton
from PyQt5.QtCore import QTimer, QTime
import sys
import serial
import pyqtgraph as pg

# --- CONSTANTES ---
VCC = 5.0
R1 = 100000.0
R3 = 100000.0
R5 = 10000.0
RES_POT = 5000.

class SensorInterface(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Monitoring Capteur Graphite / Flex")
        self.resize(900, 600)

        # Connexion Série
        try:
            self.ser = serial.Serial('COM7', 9600, timeout=0.1)
        except:
            print("Erreur: Impossible de se connecter au port série.")
            sys.exit()

        # Layout
        self.central_widget = QWidget()
        self.setCentralWidget(self.central_widget)
        self.layout = QVBoxLayout(self.central_widget)

        # Label résistance
        self.label_res = QLabel("Résistance: -- Ω")
        self.label_res.setStyleSheet("font-size: 28px; color: #e74c3c; font-weight: bold;")
        self.layout.addWidget(self.label_res)

        # Bouton pour démarrer le tracé de 10s
        self.start_btn = QPushButton("Tracer 10 secondes")
        self.start_btn.clicked.connect(self.start_10s_trace)
        self.layout.addWidget(self.start_btn)

        # Graphique
        self.graph_widget = pg.PlotWidget()
        self.graph_widget.setBackground('k')
        self.graph_widget.showGrid(x=True, y=True)
        self.graph_widget.setLabel('left', 'Résistance', units='Ω')
        self.layout.addWidget(self.graph_widget)

        self.data_x = list(range(100))
        self.data_y = [0] * 100
        self.line = self.graph_widget.plot(self.data_x, self.data_y, pen=pg.mkPen(color='g', width=2))

        # Timer lecture continue
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_data)
        self.timer.start(50)

        # Timer pour tracé temporaire de 10s
        self.trace_timer = QTimer()
        self.trace_timer.timeout.connect(self.stop_10s_trace)
        self.tracing = False

    def calculate_resistance(self, raw_byte):
        adc_val = raw_byte * 4
        if adc_val <= 0: return 0
        v_out = adc_val * (VCC / 1023.0)
        try:
            term1 = 1 + (R3 / RES_POT)
            term2 = VCC / v_out
            rc = (term1 * term2) * R1 - R1 - R5
            return round(rc, 2)
        except ZeroDivisionError:
            return 0

    def update_data(self):
        if self.ser.in_waiting > 0:
            raw_data = self.ser.read(1)
            if raw_data:
                byte_val = ord(raw_data)
                res_val = self.calculate_resistance(byte_val)
                self.label_res.setText(f"Résistance: {res_val} Ω")

                # Si mode 10s actif, tracer le graphe
                if self.tracing:
                    self.data_y = self.data_y[1:] + [res_val]
                    self.line.setData(self.data_x, self.data_y)

    def start_10s_trace(self):
        self.tracing = True
        self.data_y = [0] * 100  # reset graphe
        self.line.setData(self.data_x, self.data_y)
        self.trace_timer.start(10000)  # 10 secondes

    def stop_10s_trace(self):
        self.tracing = False
        self.trace_timer.stop()

    def closeEvent(self, event):
        self.ser.close()
        event.accept()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = SensorInterface()
    window.show()
    sys.exit(app.exec_())